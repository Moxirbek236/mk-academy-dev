generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
model User {
  id           Int   @id @default(autoincrement())
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         String   @default("STUDENT")
  fullName     String   @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  cefrLevel    String?  @map("cefr_level")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile             UserProfile?
  refreshTokens       RefreshToken[]
  groupsCreated       Group[]              @relation("TeacherGroups")
  groupMemberships    GroupMember[]
  vocabularyProgress  VocabularyProgress[]
  wordLists           WordList[]
  tasks               StudentTask[]
  gradedTasks         StudentTask[]        @relation("GradedTasks")
  createdTests        Test[]               @relation("CreatedTests")
  createdTasks        Task[]               @relation("CreatedTasks")
  testAttempts        TestAttempt[]
  achievements        StudentAchievement[]
  xpTransactions      XpTransaction[]
  leaderboards        Leaderboard[]
  ratings             Rating[]
  notifications       Notification[]
  financeTransactions FinanceTransaction[]

  @@map("users")
}

model RefreshToken {
  id         Int   @id @default(autoincrement())
  userId     Int   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  deviceInfo String?  @map("device_info")

  @@map("refresh_tokens")
}

model UserProfile {
  id                   Int    @id @default(autoincrement())
  userId               Int    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email                String?
  dateOfBirth          DateTime? @map("date_of_birth")
  language             String    @default("UZ")
  timezone             String    @default("Asia/Tashkent")
  notificationSettings String?   @map("notification_settings")

  @@map("user_profiles")
}

model Group {
  id          Int   @id @default(autoincrement())
  name        String
  description String?
  teacherId   Int   @map("teacher_id")
  teacher     User     @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  inviteCode  String   @unique @map("invite_code")
  createdAt   DateTime @default(now()) @map("created_at")

  members      GroupMember[]
  assignments  GroupAssignment[]
  courses      GroupCourse[]
  leaderboards Leaderboard[]

  @@map("groups")
}

model GroupMember {
  id        Int   @id @default(autoincrement())
  groupId   Int   @map("group_id")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId Int   @map("student_id")
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now()) @map("joined_at")
  status    String   @default("ACTIVE")

  @@unique([groupId, studentId])
  @@map("group_members")
}

model GroupAssignment {
  id         Int    @id @default(autoincrement())
  groupId    Int    @map("group_id")
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  testId     Int?   @map("test_id")
  test       Test?     @relation(fields: [testId], references: [id], onDelete: Cascade)
  taskId     Int?   @map("task_id")
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  dueDate    DateTime? @map("due_date")
  isRequired Boolean   @default(true) @map("is_required")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("group_assignments")
}

model Course {
  id          Int   @id @default(autoincrement())
  title       String
  description String?
  level       String   @default("A1") // CEFR level
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  tests  Test[]
  tasks  Task[]
  groups GroupCourse[]

  @@map("courses")
}

model GroupCourse {
  id         Int   @id @default(autoincrement())
  groupId    Int   @map("group_id")
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  courseId   Int   @map("course_id")
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([groupId, courseId])
  @@map("group_courses")
}

model Book {
  id            Int   @id @default(autoincrement())
  title         String
  author        String?
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  fileUrl       String   @map("file_url")
  cefrLevel     String?  @map("cefr_level")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("books")
}

model Rating {
  id         Int   @id @default(autoincrement())
  userId     Int   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  score      Int
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, targetType, targetId])
  @@map("ratings")
}

model Vocabulary {
  id                 Int  @id @default(autoincrement())
  word               String  @unique
  translation        String
  pronunciation      String?
  partOfSpeech       String? @map("part_of_speech")
  exampleSentence    String? @map("example_sentence")
  exampleTranslation String? @map("example_translation")
  imageUrl           String? @map("image_url")
  audioUrl           String? @map("audio_url")
  difficulty         Int     @default(1)
  cefrLevel          String? @map("cefr_level")

  progress      VocabularyProgress[]
  wordListItems WordListItem[]

  @@map("vocabularies")
}

model VocabularyProgress {
  id             Int     @id @default(autoincrement())
  studentId      Int     @map("student_id")
  student        User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  vocabularyId   Int     @map("vocabulary_id")
  vocabulary     Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  status         String     @default("NEW")
  easeFactor     Float      @default(2.5) @map("ease_factor")
  intervalDays   Int        @default(0) @map("interval_days")
  nextReviewAt   DateTime?  @map("next_review_at")
  correctCount   Int        @default(0) @map("correct_count")
  wrongCount     Int        @default(0) @map("wrong_count")
  lastReviewedAt DateTime?  @map("last_reviewed_at")

  @@unique([studentId, vocabularyId])
  @@map("vocabulary_progress")
}

model WordList {
  id        Int  @id @default(autoincrement())
  studentId Int  @map("student_id")
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name      String
  isPublic  Boolean @default(false) @map("is_public")

  items WordListItem[]

  @@map("word_lists")
}

model WordListItem {
  id           Int     @id @default(autoincrement())
  wordListId   Int     @map("word_list_id")
  wordList     WordList   @relation(fields: [wordListId], references: [id], onDelete: Cascade)
  vocabularyId Int     @map("vocabulary_id")
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now()) @map("added_at")

  @@unique([wordListId, vocabularyId])
  @@map("word_list_items")
}

model Task {
  id           Int  @id @default(autoincrement())
  title        String
  description  String?
  type         String  @default("READING")
  instructions String?
  maxScore     Int     @default(100) @map("max_score")
  createdById  Int? @map("created_by")
  createdBy    User?   @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  studentTasks StudentTask[]
  attachments  TaskAttachment[]
  assignments  GroupAssignment[]
  courseId     Int?           @map("course_id")
  course       Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model StudentTask {
  id                Int    @id @default(autoincrement())
  studentId         Int    @map("student_id")
  student           User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskId            Int    @map("task_id")
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status            String    @default("PENDING")
  submittedAt       DateTime? @map("submitted_at")
  submissionContent String?   @map("submission_content")
  score             Int?
  teacherFeedback   String?   @map("teacher_feedback")
  gradedAt          DateTime? @map("graded_at")
  gradedById        Int?   @map("graded_by")
  gradedBy          User?     @relation("GradedTasks", fields: [gradedById], references: [id], onDelete: SetNull)

  @@unique([studentId, taskId])
  @@map("student_tasks")
}

model TaskAttachment {
  id         Int @id @default(autoincrement())
  taskId     Int @map("task_id")
  task       Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileUrl    String @map("file_url")
  fileType   String @map("file_type")
  uploadedBy String @map("uploaded_by")

  @@map("task_attachments")
}

model Test {
  id               Int  @id @default(autoincrement())
  title            String
  description      String?
  type             String  @default("PRACTICE")
  cefrLevel        String? @map("cefr_level")
  timeLimitMinutes Int?    @map("time_limit_minutes")
  passingScore     Int     @default(0) @map("passing_score")
  shuffleQuestions Boolean @default(false) @map("shuffle_questions")
  maxAttempts      Int?    @map("max_attempts")
  isAdaptive       Boolean @default(false) @map("is_adaptive")
  isPublished      Boolean @default(false) @map("is_published")
  timeLimit        Int?    @map("time_limit")
  createdById      Int? @map("created_by")
  createdBy        User?   @relation("CreatedTests", fields: [createdById], references: [id], onDelete: SetNull)

  questions   Question[]
  attempts    TestAttempt[]
  assignments GroupAssignment[]
  courseId    Int?           @map("course_id")
  course      Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@map("tests")
}

model Question {
  id            Int  @id @default(autoincrement())
  testId        Int  @map("test_id")
  test          Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  type          String  @default("MCQ")
  inputType     String  @default("OPTIONS") @map("input_type")
  questionText  String  @map("question_text")
  options       String?
  correctAnswer String? @map("correct_answer")
  explanation   String?
  points        Int     @default(1)
  difficulty    Int     @default(1)
  skill         String?

  analytics QuestionAnalytics?

  @@map("questions")
}

model TestAttempt {
  id               Int    @id @default(autoincrement())
  studentId        Int    @map("student_id")
  student          User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  testId           Int    @map("test_id")
  test             Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  startedAt        DateTime  @default(now()) @map("started_at")
  submittedAt      DateTime? @map("submitted_at")
  score            Int?
  percentage       Float?
  passed           Boolean?
  timeSpentSeconds Int?      @map("time_spent_seconds")
  answers          String?
  feedback         String?

  @@map("test_attempts")
}

model QuestionAnalytics {
  id             Int   @id @default(autoincrement())
  questionId     Int   @unique @map("question_id")
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  totalAttempts  Int      @default(0) @map("total_attempts")
  correctCount   Int      @default(0) @map("correct_count")
  avgTimeSeconds Float    @default(0) @map("avg_time_seconds")

  @@map("question_analytics")
}

model Achievement {
  id             Int  @id @default(autoincrement())
  title          String
  description    String?
  iconUrl        String? @map("icon_url")
  conditionType  String  @map("condition_type")
  conditionValue Int     @map("condition_value")
  xpReward       Int     @default(0) @map("xp_reward")
  badgeColor     String? @map("badge_color")

  studentAchievements StudentAchievement[]

  @@map("achievements")
}

model StudentAchievement {
  id            Int      @id @default(autoincrement())
  studentId     Int      @map("student_id")
  student       User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievementId Int      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now()) @map("earned_at")

  @@unique([studentId, achievementId])
  @@map("student_achievements")
}

model XpTransaction {
  id          Int   @id @default(autoincrement())
  studentId   Int   @map("student_id")
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Int
  reason      String
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("xp_transactions")
}

model Leaderboard {
  id        Int  @id @default(autoincrement())
  scope     String  @default("GLOBAL")
  groupId   Int? @map("group_id")
  group     Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId Int  @map("student_id")
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score     Int     @default(0)
  rank      Int?
  period    String?

  @@map("leaderboards")
}

model Notification {
  id        Int   @id @default(autoincrement())
  userId    Int   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model FinanceTransaction {
  id        Int   @id @default(autoincrement())
  userId    Int?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount    Float
  currency  String   @default("UZS")
  type      String   @default("INCOME") // INCOME, EXPENSE
  method    String?  @default("PAYME") // PAYME, CLICK, CASH
  status    String   @default("COMPLETED")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

model SystemStats {
  id         Int   @id @default(autoincrement())
  cpuUsage   Float    @map("cpu_usage")
  ramFree    Float    @map("ram_free")
  diskSpace  Float    @map("disk_space")
  network    Int      @map("network_ms")
  uptimePerc Float    @map("uptime_perc")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("system_stats")
}
