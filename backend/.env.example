# Runtime
NODE_ENV=production
# Host port exposed by docker-compose (change if 3232 is occupied).
HOST_PORT=3232
PORT=3232
SWAGGER_ENABLED=false
CORS_ALLOW_LOCALHOST=false

# Rate limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Auth
# Generate on the server: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=30d
BCRYPT_SALT=10

# Database
# PM2/direct Node runtime uses this absolute SQLite path.
DATABASE_URL=file:/var/lib/mk-academy/mk-academy.db

# Docker runtime stores SQLite on the host here and mounts it to /app/data.
SQLITE_DATA_DIR=/var/lib/mk-academy

# Frontend
FRONTEND_URL=https://mk-academia.uz

# Telegram Bot
BOT_TOKEN=8747787098:AAGHdkbnmwgszRdkMhidp5eCthvwf-Pbx_c
MAIN_CHANNEL_ID=-1003867487868
RESULTS_CHANNEL_ID=-1003996468892
ADMIN_TELEGRAM_IDS=1603071848
ADMIN_TELEGRAM_USERNAMES=

# Initial superadmin seeder
SUPERADMIN_PHONE=+998917940303
SUPERADMIN_PASSWORD=mcacademy
SUPERADMIN_FULL_NAME=Maqsudjon
