NODE_ENV=production
PORT=3232

SWAGGER_ENABLED=false
CORS_ALLOW_LOCALHOST=false
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=30d
BCRYPT_SALT=10

# IMPORTANT:
# Use absolute SQLite path in production to avoid cwd-related issues in PM2.
DATABASE_URL=file:/tmp/mk-academy.db

FRONTEND_URL=https://mk-academia.uz
# FRONTEND_URLS=https://www.mk-academia.uz,https://mk-academia.uz

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
MAIN_CHANNEL_ID=@your_main_channel_or_id
RESULTS_CHANNEL_ID=@your_results_channel_or_id
ADMIN_TELEGRAM_IDS=100000001,100000002
ADMIN_TELEGRAM_USERNAMES=admin_username,owner_username

# Seed superadmin (optional)
SUPERADMIN_PHONE=998999992000
SUPERADMIN_PASSWORD=mcacademy
SUPERADMIN_FULL_NAME=SUPERADMIN
SUPERADMIN_EMAIL=superadmin@example.com
